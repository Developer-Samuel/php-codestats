#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../lib/autoload-finder.php';
require findAutoload();

use DeveloperSamuel\PhpCodeStats\Counter\FileCounter;

$projectRoot = getcwd();
if (!is_file($projectRoot . '/codestats-analyzer.xml')) {
    throw new RuntimeException(
        'Analyzer XML not found in project root.'
    );
}

$analyzer = new FileCounter($projectRoot);
$analyzer->analyze();
